# Nginx konfiguratsiyasi namunasi.
# Buni /etc/nginx/sites-available/sales-dashboard nomi bilan saqlang,
# so'ng /etc/nginx/sites-enabled/ ga symlink qiling.
#
# DOMENINGIZNI almashtiring: sales.deepai.uz o'rniga o'zingiznikini yozing.

server {
    listen 80;
    server_name sales.deepai.uz;

    location / {
        proxy_pass http://localhost:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
