# Supabase loyihangizdan oling: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Google Sheets integratsiyasi uchun (ixtiyoriy — bo'lmasa, ilova baribir ishlayveradi,
# faqat "Google Sheets'ga yuborish" funksiyasi xato beradi)
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIExampleKeyContentHere\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_SPREADSHEET_ID=1a2b3c4d5e6f7g8h9i0jKLmnopQRstuVWXyz

# Telegram bot orqali guruhga xabar yuborish uchun
TELEGRAM_BOT_TOKEN=123456789:AAExampleBotTokenHere
TELEGRAM_GROUP_CHAT_ID=-1001234567890

# Kunlik hisobot API'sini himoyalash uchun ixtiyoriy maxfiy so'z
# (crontab buyrug'ida ham xuddi shu qiymat ishlatiladi)
CRON_SECRET=uzun-tasodifiy-maxfiy-soz-shu-yerga

# Server tomonida ma'lumotlar bazasini to'liq o'qish uchun (kunlik hisobot uchun kerak)
# DIQQAT: bu juda maxfiy kalit — Supabase -> Settings -> API -> service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
